# --- Frontend (Vite) ---
# Supabase project URL
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon/public key
VITE_SUPABASE_ANON_KEY=your-anon-key

# Razorpay publishable key (starts with rzp_test_ or rzp_live_)
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# Backend API base URL (empty string = use Vite proxy in dev)
# In production set to your Render backend URL e.g. https://nikskart-backend.onrender.com
VITE_API_URL=

# --- Backend (server/) ---
# Supabase (server-side — service role key, bypasses RLS)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Razorpay keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret

# Allowed frontend origin in production (no trailing slash)
FRONTEND_ORIGIN=https://nikskart-frontend.onrender.com

# Admin key to protect /api/orders/all and /api/customers
# Generate with: openssl rand -hex 32
ADMIN_KEY=change-me-to-a-random-secret
